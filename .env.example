# Development / local demo settings
#
# Copy this file to `.env` for `docker-compose.dev.yml`.
# For `docker-compose.prod.yml`, start from `.env.prod.example` instead.

# Django settings
DJANGO_SECRET_KEY=portfolio-local-secret-key-change-before-public-deployment
DJANGO_SETTINGS_MODULE=backend.settings.dev
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_BASE_URL=http://localhost:3000
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_COOKIES=False
DJANGO_HSTS_SECONDS=0

# Docker PostgreSQL settings
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=crm_db
# Test DB
POSTGRES_TEST_DB=crm_test_db

# Stripe Payment Settings
STRIPE_SECRET_KEY=test_secret_key
STRIPE_PUBLISHABLE_KEY=test_publishable_key
STRIPE_WEBHOOK_SECRET=test_webhook_secret

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=portfolio@example.com
SERVER_EMAIL=portfolio@example.com

# Celery and Redis settings
CELERY_BROKER_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# Amazon S3 / local media
USE_S3_STORAGE=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ca-central-1
AWS_S3_CUSTOM_DOMAIN=

# CSRF and CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8080
