# Production / production-like Docker settings
#
# Copy this file to `.env` before running:
# docker compose -f docker-compose.prod.yml up --build -d
#
# Replace all secret-like values before any real public deployment.

# Django settings
DJANGO_SECRET_KEY=localprod-django-secret-9f4c1b7a2e6d8c0a5f3b1a7d9e2c6f8a
DJANGO_SETTINGS_MODULE=backend.settings.prod
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_BASE_URL=http://localhost:8080
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_COOKIES=False
DJANGO_HSTS_SECONDS=0

# Docker PostgreSQL settings
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=localprod-postgres-password-7d3c9a1e
POSTGRES_DB=crm_db
POSTGRES_TEST_DB=crm_test_db

# Stripe Payment Settings
# These local production-like values let the stack boot. Use real Stripe keys for payments.
STRIPE_SECRET_KEY=localprod-stripe-secret-8d2f6a4c1e9b
STRIPE_PUBLISHABLE_KEY=localprod-stripe-publishable-3a7e1c9d5b2f
STRIPE_WEBHOOK_SECRET=localprod-stripe-webhook-4c9e2a6f8b1d

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=portfolio@example.com
SERVER_EMAIL=portfolio@example.com

# Celery and Redis settings
CELERY_BROKER_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# Storage
# False: persistent Docker media volume at /app/media.
# True: S3 storage; fill AWS values below.
USE_S3_STORAGE=True
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ca-central-1
AWS_S3_CUSTOM_DOMAIN=

# CSRF and CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost:8080
